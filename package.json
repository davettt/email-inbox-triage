{
  "name": "email-inbox",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "npm run kill-port && concurrently --kill-others-on-fail \"vite\" \"nodemon --ignore local_data/ server/index.js\"",
    "kill-port": "lsof -ti :3006 | xargs kill -9 2>/dev/null; exit 0",
    "build": "vite build && node -e \"fs.writeFileSync('.last-build',Date.now().toString())\"",
    "start": "node server/index.js",
    "restart:pm2": "npm run build && pm2 restart email-inbox",
    "auth": "node scripts/setup-gmail-auth.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "security": "npm audit --audit-level=high",
    "check": "npm run lint && npm run format:check && npm run type-check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "open": "^10.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.40",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.4.2"
  }
}
